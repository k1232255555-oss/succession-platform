NEXT_PUBLIC_APP_URL=https://your-production-domain.example
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Set both values in production to protect the closed dashboard with Basic Auth.
# Leave them unset locally when you do not need the access gate.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# Enable only while creating the first OWNER account at /setup.
ALLOW_BOOTSTRAP_ADMIN=false

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BILLING_ENABLED=false
STRIPE_STANDARD_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

OPENAI_API_KEY=
OPENAI_MATCHING_MODEL=gpt-5.5-mini

NOTIFICATION_EMAILS_ENABLED=false

# Contact form delivery. These three values are required in production even
# when NOTIFICATION_EMAILS_ENABLED remains false.
RESEND_API_KEY=
EMAIL_FROM=Succession Club <no-reply@your-production-domain.example>
NOTIFICATION_REPLY_TO=
CONTACT_TO_EMAIL=
SUPPORT_EMAIL=
