NEXT_PUBLIC_APP_URL=https://your-production-domain.example
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Set both values in production to protect the closed dashboard with Basic Auth.
# Leave them unset locally when you do not need the access gate.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# Enable only while creating the first OWNER account at /setup.
ALLOW_BOOTSTRAP_ADMIN=false

# Reserved for future Stripe integration.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
