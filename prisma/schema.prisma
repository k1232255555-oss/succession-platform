generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  SESSION_REVOKED
  USER_CREATED
  USER_UPDATED
  CANDIDATE_VIEWED
  CANDIDATE_CREATED
  CANDIDATE_UPDATED
  CANDIDATE_DELETED
  SCOUT_CREATED
  SCOUT_UPDATED
  STRIPE_CUSTOMER_LINKED
  BILLING_CHECKOUT_STARTED
  BILLING_PORTAL_STARTED
  BILLING_SUBSCRIPTION_UPDATED
  BILLING_PAYMENT_FAILED
}

enum CandidateReviewStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum ScoutStatus {
  DRAFT
  SENT
  IN_REVIEW
  MEETING
  ACCEPTED
  DECLINED
  CANCELED
}

enum BillingPlan {
  FREE
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum BillingSubscriptionStatus {
  FREE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

enum BillingInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model Company {
  id                           String                    @id @default(cuid())
  name                         String
  slug                         String                    @unique
  status                       String                    @default("active")
  billingPlan                  BillingPlan               @default(FREE)
  billingStatus                BillingSubscriptionStatus @default(FREE)
  stripeCustomerId             String?                   @unique
  stripeSubscriptionId         String?                   @unique
  stripePriceId                String?
  subscriptionCurrentPeriodEnd DateTime?
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
  auditLogs                    AuditLog[]
  billingInvoices              BillingInvoice[]
  candidates                   SuccessorCandidate[]
  scoutRequests                ScoutRequest[]
  stripeWebhookEvents          StripeWebhookEvent[]
  users                        CompanyUser[]
}

model CompanyUser {
  id            String         @id @default(cuid())
  companyId     String
  email         String         @unique
  name          String
  role          UserRole       @default(MEMBER)
  passwordHash  String
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditLogs     AuditLog[]
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scoutRequests ScoutRequest[]
  sessions      Session[]

  @@index([companyId])
  @@index([role])
}

model Session {
  id         String      @id @default(cuid())
  tokenHash  String      @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime    @default(now())
  lastSeenAt DateTime    @default(now())
  user       CompanyUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id        String       @id @default(cuid())
  companyId String
  actorId   String?
  action    AuditAction
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime     @default(now())
  actor     CompanyUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([actorId])
  @@index([action])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([success, createdAt])
}

model BillingInvoice {
  id                   String               @id @default(cuid())
  companyId            String
  stripeInvoiceId      String               @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  number               String?
  status               BillingInvoiceStatus
  amountDue            Int                  @default(0)
  amountPaid           Int                  @default(0)
  currency             String               @default("jpy")
  hostedInvoiceUrl     String?
  invoicePdf           String?
  dueDate              DateTime?
  paidAt               DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([status])
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  companyId     String?
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([type])
}

model SuccessorCandidate {
  id                        String                @id @default(cuid())
  companyId                 String
  name                      String
  age                       Int
  region                    String
  desiredIndustries         String[]
  skills                    String[]
  career                    String
  selfPr                    String
  aiUsageLevel              Int                   @default(3)
  fieldExperienceLevel      Int                   @default(3)
  successionMotivationLevel Int                   @default(3)
  reviewStatus              CandidateReviewStatus @default(UNDER_REVIEW)
  isFeatured                Boolean               @default(false)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  company                   Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scoutRequests             ScoutRequest[]

  @@index([companyId, reviewStatus])
  @@index([companyId, isFeatured])
  @@index([companyId, region])
  @@index([createdAt])
}

model ScoutRequest {
  id                String             @id @default(cuid())
  companyId         String
  candidateId       String
  createdById       String?
  status            ScoutStatus        @default(SENT)
  message           String
  feeAcknowledged   Boolean            @default(false)
  proposedMeetingAt DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  candidate         SuccessorCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy         CompanyUser?       @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([candidateId])
  @@index([createdById])
  @@index([createdAt])
}
