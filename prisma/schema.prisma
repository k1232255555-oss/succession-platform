generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  SESSION_REVOKED
  USER_CREATED
  USER_UPDATED
  CANDIDATE_VIEWED
  CANDIDATE_CREATED
  CANDIDATE_UPDATED
  CANDIDATE_DELETED
  SCOUT_CREATED
  SCOUT_UPDATED
  AI_MATCH_RECALCULATED
  MESSAGE_THREAD_CREATED
  MESSAGE_SENT
  MESSAGE_READ
  MESSAGE_THREAD_CLOSED
  STRIPE_CUSTOMER_LINKED
  BILLING_CHECKOUT_STARTED
  BILLING_PORTAL_STARTED
  BILLING_SUBSCRIPTION_UPDATED
  BILLING_PAYMENT_FAILED
  NOTIFICATION_EMAIL_SENT
  NOTIFICATION_EMAIL_FAILED
}

enum CandidateReviewStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum ScoutStatus {
  DRAFT
  SENT
  IN_REVIEW
  MEETING
  ACCEPTED
  DECLINED
  CANCELED
}

enum BillingPlan {
  FREE
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum BillingSubscriptionStatus {
  FREE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

enum BillingInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum MessageThreadStatus {
  OPEN
  CLOSED
}

enum MessageSenderType {
  COMPANY_USER
  CANDIDATE
  OPERATIONS
}

enum NotificationChannel {
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  SKIPPED
  FAILED
}

enum NotificationType {
  SCOUT_CREATED
  MESSAGE_SENT
  BILLING_PAYMENT_FAILED
  MESSAGE_THREAD_CLOSED
}

model Company {
  id                           String                    @id @default(cuid())
  name                         String
  slug                         String                    @unique
  status                       String                    @default("active")
  billingPlan                  BillingPlan               @default(FREE)
  billingStatus                BillingSubscriptionStatus @default(FREE)
  stripeCustomerId             String?                   @unique
  stripeSubscriptionId         String?                   @unique
  stripePriceId                String?
  subscriptionCurrentPeriodEnd DateTime?
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
  auditLogs                    AuditLog[]
  billingInvoices              BillingInvoice[]
  candidates                   SuccessorCandidate[]
  aiMatchResults               AiMatchResult[]
  messageThreads               MessageThread[]
  messages                     Message[]
  notificationLogs             NotificationLog[]
  scoutRequests                ScoutRequest[]
  stripeWebhookEvents          StripeWebhookEvent[]
  users                        CompanyUser[]
}

model CompanyUser {
  id                    String               @id @default(cuid())
  companyId             String
  email                 String               @unique
  name                  String
  role                  UserRole             @default(MEMBER)
  passwordHash          String
  isActive              Boolean              @default(true)
  lastLoginAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  auditLogs             AuditLog[]
  company               Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdMessageThreads MessageThread[]      @relation("MessageThreadCreatedBy")
  messageReadReceipts   MessageReadReceipt[]
  notificationLogs      NotificationLog[]
  sentMessages          Message[]
  scoutRequests         ScoutRequest[]
  sessions              Session[]

  @@index([companyId])
  @@index([role])
}

model Session {
  id         String      @id @default(cuid())
  tokenHash  String      @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime    @default(now())
  lastSeenAt DateTime    @default(now())
  user       CompanyUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id        String       @id @default(cuid())
  companyId String
  actorId   String?
  action    AuditAction
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime     @default(now())
  actor     CompanyUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([actorId])
  @@index([action])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([success, createdAt])
}

model BillingInvoice {
  id                   String               @id @default(cuid())
  companyId            String
  stripeInvoiceId      String               @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  number               String?
  status               BillingInvoiceStatus
  amountDue            Int                  @default(0)
  amountPaid           Int                  @default(0)
  currency             String               @default("jpy")
  hostedInvoiceUrl     String?
  invoicePdf           String?
  dueDate              DateTime?
  paidAt               DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([status])
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  companyId     String?
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([type])
}

model SuccessorCandidate {
  id                        String                @id @default(cuid())
  companyId                 String
  name                      String
  age                       Int
  region                    String
  desiredIndustries         String[]
  skills                    String[]
  career                    String
  selfPr                    String
  aiUsageLevel              Int                   @default(3)
  fieldExperienceLevel      Int                   @default(3)
  successionMotivationLevel Int                   @default(3)
  reviewStatus              CandidateReviewStatus @default(UNDER_REVIEW)
  isFeatured                Boolean               @default(false)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  company                   Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  aiMatchResults            AiMatchResult[]
  scoutRequests             ScoutRequest[]

  @@index([companyId, reviewStatus])
  @@index([companyId, isFeatured])
  @@index([companyId, region])
  @@index([createdAt])
}

model AiMatchResult {
  id                        String             @id @default(cuid())
  companyId                 String
  candidateId               String
  score                     Int
  reasons                   String[]
  strengths                 String[]
  concerns                  String[]
  recommendation            String
  expectedContribution      String[]
  cautionPoints             String[]
  model                     String
  promptVersion             String             @default("2026-07-06")
  isFallback                Boolean            @default(false)
  companyProfileUpdatedAt   DateTime
  candidateProfileUpdatedAt DateTime
  calculatedAt              DateTime           @default(now())
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  company                   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidate                 SuccessorCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([companyId, candidateId])
  @@index([companyId, score])
  @@index([candidateId])
  @@index([calculatedAt])
}

model ScoutRequest {
  id                String             @id @default(cuid())
  companyId         String
  candidateId       String
  createdById       String?
  status            ScoutStatus        @default(SENT)
  message           String
  feeAcknowledged   Boolean            @default(false)
  proposedMeetingAt DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  candidate         SuccessorCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy         CompanyUser?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  messageThread     MessageThread?

  @@index([companyId, status])
  @@index([candidateId])
  @@index([createdById])
  @@index([createdAt])
}

model MessageThread {
  id             String              @id @default(cuid())
  companyId      String
  scoutRequestId String              @unique
  createdById    String?
  subject        String
  status         MessageThreadStatus @default(OPEN)
  closedAt       DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scoutRequest   ScoutRequest        @relation(fields: [scoutRequestId], references: [id], onDelete: Cascade)
  createdBy      CompanyUser?        @relation("MessageThreadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  messages       Message[]

  @@index([companyId, status])
  @@index([createdById])
  @@index([updatedAt])
}

model Message {
  id           String               @id @default(cuid())
  threadId     String
  companyId    String
  senderUserId String?
  senderType   MessageSenderType    @default(COMPANY_USER)
  senderName   String
  body         String
  createdAt    DateTime             @default(now())
  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  thread       MessageThread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUser   CompanyUser?         @relation(fields: [senderUserId], references: [id], onDelete: SetNull)
  readReceipts MessageReadReceipt[]

  @@index([threadId, createdAt])
  @@index([companyId, createdAt])
  @@index([senderUserId])
}

model MessageReadReceipt {
  id        String      @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime    @default(now())
  message   Message     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      CompanyUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
}

model NotificationLog {
  id                String              @id @default(cuid())
  companyId         String
  recipientUserId   String?
  recipientEmail    String
  type              NotificationType
  channel           NotificationChannel @default(EMAIL)
  status            NotificationStatus  @default(PENDING)
  subject           String
  body              String
  provider          String?
  providerMessageId String?
  errorMessage      String?
  metadata          Json?
  createdAt         DateTime            @default(now())
  sentAt            DateTime?
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recipientUser     CompanyUser?        @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([recipientUserId])
  @@index([status])
  @@index([type])
}
